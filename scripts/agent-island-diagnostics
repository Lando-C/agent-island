#!/usr/bin/env bash
# Copyright (c) 2026 Ling
# SPDX-License-Identifier: MIT

set -uo pipefail

REDACTED=0
if [[ "${1:-}" == "--redacted" ]]; then
  REDACTED=1
fi

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
DATA_DIR="$HOME/.agent-island"
EVENTS="$DATA_DIR/events.jsonl"
LOG="$DATA_DIR/agent-island.log"
BRIDGE="$SCRIPT_DIR/agent-island-bridge.py"
PROBE="$SCRIPT_DIR/codex-broker-probe"
INSTALL_HOOKS="$SCRIPT_DIR/install-hooks"
AUTO_APPROVAL="$DATA_DIR/auto-approval.json"
HOOK_SOCKET="$DATA_DIR/hook.sock"
TRANSPORT_HEALTH="$DATA_DIR/transport-health.json"

pass_count=0
warn_count=0
fail_count=0

status() {
  local level="$1"
  local name="$2"
  local detail="${3:-}"
  if [[ "$REDACTED" == "1" && -n "$detail" ]]; then
    detail="$(redact "$detail")"
  fi
  case "$level" in
    PASS) pass_count=$((pass_count + 1)) ;;
    WARN) warn_count=$((warn_count + 1)) ;;
    FAIL) fail_count=$((fail_count + 1)) ;;
  esac
  if [[ -n "$detail" ]]; then
    printf '[%s] %s — %s\n' "$level" "$name" "$detail"
  else
    printf '[%s] %s\n' "$level" "$name"
  fi
}

redact() {
  local value="$1"
  value="${value//$HOME/~}"
  printf '%s' "$value" | sed -E 's/[0-9a-fA-F]{8}-[0-9a-fA-F-]{27,}/<session>/g'
}

section() {
  printf '\n## %s\n' "$1"
}

command_path() {
  local name="$1"
  if command -v "$name" >/dev/null 2>&1; then
    command -v "$name"
    return 0
  fi
  for path in "/opt/homebrew/bin/$name" "/usr/local/bin/$name" "/usr/bin/$name" "/Applications/${name}.app/Contents/MacOS/$name"; do
    if [[ -x "$path" ]]; then
      echo "$path"
      return 0
    fi
  done
  return 1
}

json_contains_bridge() {
  local path="$1"
  [[ -f "$path" ]] || return 2
  python3 - "$path" <<'PY'
import json, sys
path = sys.argv[1]
try:
    data = json.load(open(path, encoding="utf-8"))
except Exception:
    sys.exit(3)
text = json.dumps(data, ensure_ascii=False)
sys.exit(0 if "agent-island-bridge.py" in text else 1)
PY
}

line_count() {
  [[ -f "$1" ]] && wc -l < "$1" | tr -d ' ' || echo 0
}

mtime_epoch() {
  [[ -e "$1" ]] && stat -f %m "$1" 2>/dev/null || echo 0
}

printf '# Agent Island Diagnostics\n'
printf 'Generated: %s\n' "$(date '+%Y-%m-%d %H:%M:%S %Z')"
if [[ "$REDACTED" == "1" ]]; then
  printf 'Script: agent-island-diagnostics\n'
  printf 'Redaction: enabled\n'
else
  printf 'Script: %s\n' "$0"
fi

section "App"
if pgrep -f '/Applications/Agent Island.app/Contents/MacOS/AgentIsland' >/dev/null 2>&1; then
  status PASS "Agent Island process" "$(pgrep -fl '/Applications/Agent Island.app/Contents/MacOS/AgentIsland' | head -n 1)"
else
  status WARN "Agent Island process" "not running from /Applications"
fi
if [[ -x "/Applications/Agent Island.app/Contents/MacOS/AgentIsland" ]]; then
  status PASS "Installed app binary" "/Applications/Agent Island.app"
else
  status WARN "Installed app binary" "missing /Applications/Agent Island.app"
fi
if [[ -x "$BRIDGE" ]]; then
  if [[ "$REDACTED" == "1" ]]; then
    status PASS "Hook bridge executable" "present"
  else
    status PASS "Hook bridge executable" "$BRIDGE"
  fi
else
  status FAIL "Hook bridge executable" "$BRIDGE is missing or not executable"
fi

section "Hooks"
if json_contains_bridge "$HOME/.claude/settings.json"; then
  status PASS "Claude Code hooks" "$HOME/.claude/settings.json"
else
  rc=$?
  if [[ "$rc" == "2" ]]; then
    status WARN "Claude Code hooks" "~/.claude/settings.json not found"
  else
    status FAIL "Claude Code hooks" "agent-island bridge not installed or invalid JSON"
  fi
fi
if json_contains_bridge "$HOME/.codex/hooks.json"; then
  status PASS "Codex CLI hooks" "$HOME/.codex/hooks.json"
else
  rc=$?
  if [[ "$rc" == "2" ]]; then
    status WARN "Codex CLI hooks" "~/.codex/hooks.json not found"
  else
    status FAIL "Codex CLI hooks" "agent-island bridge not installed or invalid JSON"
  fi
fi
if [[ -f "$HOME/.codex/config.toml" ]] && grep -Eq '^[[:space:]]*hooks[[:space:]]*=[[:space:]]*true' "$HOME/.codex/config.toml"; then
  status PASS "Codex hooks feature" "$HOME/.codex/config.toml"
else
  status WARN "Codex hooks feature" "config.toml does not visibly contain hooks = true"
fi
if [[ -x "$INSTALL_HOOKS" ]]; then
  status PASS "One-click hook repair script" "$INSTALL_HOOKS"
else
  status FAIL "One-click hook repair script" "$INSTALL_HOOKS missing"
fi

section "Hook Socket"
if [[ -S "$HOOK_SOCKET" ]]; then
  mode="$(stat -f %Lp "$HOOK_SOCKET" 2>/dev/null || echo unknown)"
  status PASS "Hook socket" "$HOOK_SOCKET mode=$mode"
elif pgrep -f '/Applications/Agent Island.app/Contents/MacOS/AgentIsland' >/dev/null 2>&1; then
  status FAIL "Hook socket" "$HOOK_SOCKET missing while Agent Island is running"
else
  status WARN "Hook socket" "$HOOK_SOCKET missing; Agent Island is not running"
fi

section "Transport Health"
if [[ -f "$TRANSPORT_HEALTH" ]]; then
  python3 - "$TRANSPORT_HEALTH" "$REDACTED" <<'PY'
import json, os, re, sys
path, redacted = sys.argv[1], sys.argv[2] == "1"
try:
    values = json.load(open(path, encoding="utf-8"))
except Exception as exc:
    print(f"[WARN] Transport health file — invalid: {exc}")
    raise SystemExit(0)
if not isinstance(values, list):
    print("[WARN] Transport health file — expected a list")
    raise SystemExit(0)
home = os.path.expanduser("~")
for value in values:
    if not isinstance(value, dict):
        continue
    name = value.get("name") or value.get("id") or "transport"
    state = value.get("state") or "unknown"
    protocol = value.get("protocolVersion") or "unknown protocol"
    last = value.get("lastSuccessAt") or "never"
    failure = value.get("failure")
    endpoint = value.get("endpoint")
    if redacted:
        endpoint = endpoint.replace(home, "~") if isinstance(endpoint, str) else endpoint
        failure = re.sub(r"[0-9a-fA-F]{8}-[0-9a-fA-F-]{27,}", "<session>", failure or "")
    detail = f"state={state} protocol={protocol} last_success={last}"
    if endpoint:
        detail += f" endpoint={endpoint}"
    if failure:
        detail += f" failure={failure}"
    print(f"[INFO] {name} — {detail}")
PY
else
  status WARN "Transport health file" "$TRANSPORT_HEALTH not written yet; start Agent Island once"
fi

section "Event Stream"
if [[ -f "$EVENTS" ]]; then
  count="$(line_count "$EVENTS")"
  age=$(( $(date +%s) - $(mtime_epoch "$EVENTS") ))
  status PASS "Events log" "$EVENTS lines=$count age=${age}s"
  if [[ "$REDACTED" == "1" ]]; then
    last="$(tail -n 1 "$EVENTS" 2>/dev/null)"
  else
    last="$(tail -n 1 "$EVENTS" 2>/dev/null | cut -c 1-240)"
  fi
  if [[ -n "$last" ]]; then
    if [[ "$REDACTED" == "1" ]]; then
      python3 - "$last" <<'PY'
import json, sys
try:
    value = json.loads(sys.argv[1])
    fields = {key: value.get(key) for key in ("agent", "family", "surface", "status", "phase", "event", "ts") if value.get(key) is not None}
    print("Last event metadata: " + json.dumps(fields, ensure_ascii=False, separators=(",", ":")))
except Exception:
    print("Last event metadata: unavailable")
PY
    else
      printf 'Last event: %s\n' "$last"
    fi
  fi
else
  status WARN "Events log" "$EVENTS not found yet"
fi
if [[ -f "$LOG" ]]; then
  status PASS "App log" "$LOG"
else
  status WARN "App log" "$LOG not found yet"
fi

section "Permissions"
accessibility="$(osascript -e 'tell application "System Events" to UI elements enabled' 2>&1)"
if [[ "$accessibility" == "true" ]]; then
  status PASS "System Events UI scripting bridge" "enabled"
else
  status WARN "System Events UI scripting bridge" "$accessibility"
fi
status INFO "Agent Island direct Accessibility" "per-app TCC cannot be verified by this CLI; use Open Accessibility Settings and ensure Agent Island is enabled"
automation="$(osascript -e 'tell application "System Events" to count processes' 2>&1)"
if [[ "$automation" =~ ^[0-9]+$ ]]; then
  status PASS "Apple Events / System Events" "process count=$automation"
else
  status WARN "Apple Events / System Events" "$automation"
fi

section "Codex Broker"
if [[ -x "$PROBE" ]]; then
  broker_output="$("$PROBE" --limit 20 --read-visible-details --read-limit 2 2>&1)"
  broker_rc=$?
  if [[ "$broker_rc" == "0" ]]; then
    visible="$(python3 - "$broker_output" <<'PY'
import json, sys
try:
    data = json.loads(sys.argv[1])
    threads = data.get("threads") or []
    visible = [
        t for t in threads
        if not t.get("auxiliary") and not t.get("isAuxiliary") and not t.get("is_auxiliary")
    ]
    print(f"socket={data.get('socket')} threads={len(threads)} visible={len(visible)}")
except Exception:
    print(sys.argv[1][:240])
PY
)"
    status PASS "Codex broker probe" "$visible"
  else
    status WARN "Codex broker probe" "$(echo "$broker_output" | head -n 1 | cut -c 1-240)"
  fi
else
  status WARN "Codex broker probe" "$PROBE missing"
fi

section "Terminal Jump"
if tmux_path="$(command_path tmux)"; then
  if "$tmux_path" list-sessions >/tmp/agent-island-tmux.out 2>/tmp/agent-island-tmux.err; then
    status PASS "tmux" "$tmux_path sessions=$(wc -l < /tmp/agent-island-tmux.out | tr -d ' ')"
  else
    status WARN "tmux" "$tmux_path installed, no accessible server ($(head -n 1 /tmp/agent-island-tmux.err 2>/dev/null))"
  fi
else
  status WARN "tmux" "not installed"
fi
for tool in wezterm kitten kitty osascript; do
  if path="$(command_path "$tool")"; then
    status PASS "terminal helper: $tool" "$path"
  else
    status WARN "terminal helper: $tool" "not found"
  fi
done
for app in "iTerm2" "Terminal" "Ghostty" "WezTerm" "Warp" "kitty" "cmux" "Kaku"; do
  if pgrep -x "$app" >/dev/null 2>&1 || pgrep -f "/${app}.app/" >/dev/null 2>&1; then
    status PASS "running terminal: $app" "detected"
  else
    status WARN "running terminal: $app" "not running"
  fi
done

section "Web/App Surfaces"
if pgrep -f '/Applications/Codex.app/' >/dev/null 2>&1 || pgrep -f '/Applications/ChatGPT.app/' >/dev/null 2>&1 || pgrep -f 'codex app-server' >/dev/null 2>&1; then
  status PASS "running app: Codex" "com.openai.codex detected"
else
  status WARN "running app: Codex" "not running"
fi
if pgrep -f '/Applications/ChatGPT Classic.app/' >/dev/null 2>&1; then
  status PASS "running app: ChatGPT" "com.openai.chat detected"
else
  status WARN "running app: ChatGPT" "not running"
fi
for app in "Claude" "Claude Science" "Google Chrome" "Safari"; do
  if pgrep -x "$app" >/dev/null 2>&1 || pgrep -f "/${app}.app/" >/dev/null 2>&1; then
    status PASS "running app: $app" "detected"
  else
    status WARN "running app: $app" "not running"
  fi
done

section "Auto Approval"
if [[ -f "$AUTO_APPROVAL" ]]; then
  enabled="$(python3 - "$AUTO_APPROVAL" <<'PY'
import json, sys
try:
    data = json.load(open(sys.argv[1], encoding="utf-8"))
    print("enabled=true" if data.get("enabled") else "enabled=false")
except Exception as exc:
    print(f"invalid: {exc}")
PY
)"
  status WARN "Auto approval" "$enabled; dangerous tools are still never auto-approved"
else
  status PASS "Auto approval" "disabled by default; create ~/.agent-island/auto-approval.json to opt in"
fi

section "Summary"
printf 'PASS=%d WARN=%d FAIL=%d\n' "$pass_count" "$warn_count" "$fail_count"
if [[ "$fail_count" -gt 0 ]]; then
  exit 2
fi
exit 0
