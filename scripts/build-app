#!/usr/bin/env bash
# Copyright (c) 2026 Ling
# SPDX-License-Identifier: MIT

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
APP_DIR="$ROOT/dist/Agent Island.app"
CONTENTS="$APP_DIR/Contents"
MACOS="$CONTENTS/MacOS"
RESOURCES="$CONTENTS/Resources"
VERSION="${AGENT_ISLAND_VERSION:-0.1.0}"
BUILD_NUMBER="${AGENT_ISLAND_BUILD_NUMBER:-1}"

[[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || {
  echo "invalid AGENT_ISLAND_VERSION: $VERSION" >&2
  exit 2
}
[[ "$BUILD_NUMBER" =~ ^[0-9]+$ ]] || {
  echo "invalid AGENT_ISLAND_BUILD_NUMBER: $BUILD_NUMBER" >&2
  exit 2
}

cd "$ROOT"
build_args=(-c release)
if [[ "${AGENT_ISLAND_UNIVERSAL:-0}" == "1" ]]; then
  build_args+=(--arch arm64 --arch x86_64)
fi
swift build "${build_args[@]}"
binary_dir="$(swift build "${build_args[@]}" --show-bin-path)"

rm -rf "$APP_DIR"
mkdir -p "$MACOS" "$RESOURCES"
cp "$binary_dir/AgentIsland" "$MACOS/AgentIsland"
mkdir -p "$RESOURCES/scripts"
cp -R "$ROOT/scripts/." "$RESOURCES/scripts/"
find "$RESOURCES/scripts" -type d -name "__pycache__" -prune -exec rm -rf {} +
find "$RESOURCES/scripts" -type f -exec chmod +x {} +

cat > "$CONTENTS/Info.plist" <<'PLIST'
<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>CFBundleDevelopmentRegion</key>
  <string>en</string>
  <key>CFBundleExecutable</key>
  <string>AgentIsland</string>
  <key>CFBundleIdentifier</key>
  <string>local.agent-island</string>
  <key>CFBundleInfoDictionaryVersion</key>
  <string>6.0</string>
  <key>CFBundleName</key>
  <string>Agent Island</string>
  <key>CFBundlePackageType</key>
  <string>APPL</string>
  <key>CFBundleShortVersionString</key>
  <string>0.1.0</string>
  <key>CFBundleVersion</key>
  <string>1</string>
  <key>LSMinimumSystemVersion</key>
  <string>13.0</string>
  <key>LSUIElement</key>
  <true/>
  <key>NSHighResolutionCapable</key>
  <true/>
  <key>NSAppleEventsUsageDescription</key>
  <string>Agent Island uses Apple Events to inspect frontmost ChatGPT/browser UI state and focus the related app window when clicked.</string>
</dict>
</plist>
PLIST

/usr/libexec/PlistBuddy -c "Set :CFBundleShortVersionString $VERSION" "$CONTENTS/Info.plist"
/usr/libexec/PlistBuddy -c "Set :CFBundleVersion $BUILD_NUMBER" "$CONTENTS/Info.plist"

if [[ -n "${AGENT_ISLAND_SIGNING_IDENTITY:-}" ]]; then
  codesign --force --deep --options runtime --sign "$AGENT_ISLAND_SIGNING_IDENTITY" "$APP_DIR"
else
  # Keep a stable local designated requirement so Accessibility permission does
  # not fall back to a new cdhash after every development build.
  codesign --force --deep --sign - \
    --requirements '=designated => identifier "local.agent-island"' \
    "$APP_DIR"
fi

echo "$APP_DIR"
