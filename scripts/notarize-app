#!/usr/bin/env bash
# Copyright (c) 2026 Ling
# SPDX-License-Identifier: MIT

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
APP="$ROOT/dist/Agent Island.app"
OUTPUT_DIR="$ROOT/dist"

usage() {
  printf 'Usage: %s [--app PATH] [--output DIRECTORY]\n' "$0"
}

while [[ "$#" -gt 0 ]]; do
  case "$1" in
    --app) APP="${2:-}"; shift 2 ;;
    --output) OUTPUT_DIR="${2:-}"; shift 2 ;;
    -h|--help) usage; exit 0 ;;
    *) usage >&2; exit 64 ;;
  esac
done

[[ -d "$APP" ]] || { printf 'Missing app bundle: %s\n' "$APP" >&2; exit 2; }
[[ -n "${AGENT_ISLAND_SIGNING_IDENTITY:-}" ]] || {
  printf 'AGENT_ISLAND_SIGNING_IDENTITY must be a Developer ID Application identity\n' >&2
  exit 2
}
mkdir -p "$OUTPUT_DIR"

codesign --verify --deep --strict --verbose=2 "$APP"
SIGNATURE_INFO="$(codesign -dv --verbose=2 "$APP" 2>&1 || true)"
[[ "$SIGNATURE_INFO" == *"Developer ID Application"* ]] || {
  printf 'The app is not signed with a Developer ID Application certificate\n' >&2
  exit 2
}

ZIP="$OUTPUT_DIR/Agent-Island-notarization.zip"
rm -f "$ZIP"
ditto -c -k --keepParent "$APP" "$ZIP"

notary_args=(submit "$ZIP" --wait)
if [[ -n "${AGENT_ISLAND_NOTARY_KEYCHAIN_PROFILE:-}" ]]; then
  notary_args+=(--keychain-profile "$AGENT_ISLAND_NOTARY_KEYCHAIN_PROFILE")
elif [[ -n "${AGENT_ISLAND_NOTARY_KEY_FILE:-}" && -n "${AGENT_ISLAND_NOTARY_KEY_ID:-}" && -n "${AGENT_ISLAND_NOTARY_ISSUER_ID:-}" ]]; then
  notary_args+=(
    --key "$AGENT_ISLAND_NOTARY_KEY_FILE"
    --key-id "$AGENT_ISLAND_NOTARY_KEY_ID"
    --issuer "$AGENT_ISLAND_NOTARY_ISSUER_ID"
  )
else
  printf 'Provide AGENT_ISLAND_NOTARY_KEYCHAIN_PROFILE or API-key variables for notarytool\n' >&2
  exit 2
fi

xcrun notarytool "${notary_args[@]}"
xcrun stapler staple "$APP"
xcrun stapler validate "$APP"
spctl --assess --type execute --verbose=4 "$APP"

rm -f "$ZIP"
ditto -c -k --keepParent "$APP" "$OUTPUT_DIR/Agent-Island-macOS.zip"
shasum -a 256 "$OUTPUT_DIR/Agent-Island-macOS.zip" > "$OUTPUT_DIR/SHA256SUMS"
printf '%s\n' "$OUTPUT_DIR/Agent-Island-macOS.zip"
