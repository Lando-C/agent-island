#!/usr/bin/env bash
# Copyright (c) 2026 Ling
# SPDX-License-Identifier: MIT

set -euo pipefail

require_xctest=false
if [[ "${1:-}" == "--require-xctest" ]]; then
  require_xctest=true
elif [[ $# -gt 0 ]]; then
  echo "Usage: scripts/test-swift [--require-xctest]" >&2
  exit 64
fi

developer_dir="$(xcode-select -p 2>/dev/null || true)"
test_flags=(--enable-xctest --disable-swift-testing -Xswiftc -DAGENT_ISLAND_USE_XCTEST)
platform_path="$(xcrun --sdk macosx --show-sdk-platform-path 2>/dev/null || true)"
if [[ -n "$platform_path" ]]; then
  if swift test --help | grep -q -- '--enable-xctest'; then
    exec swift test "${test_flags[@]}"
  fi
  # Older Xcode SwiftPM does not expose the runner toggles. On that toolchain
  # Swift Testing is unavailable, so `swift test` already runs XCTest.
  exec swift test
fi

if [[ "$developer_dir" == "/Library/Developer/CommandLineTools" ]]; then
  framework_root="$developer_dir/Library/Developer/Frameworks"
  swift build --build-tests \
    -Xswiftc -DAGENT_ISLAND_USE_XCTEST \
    -Xswiftc -F -Xswiftc "$framework_root" \
    -Xlinker -F -Xlinker "$framework_root" \
    -Xlinker -rpath -Xlinker "$framework_root"
else
  swift build --build-tests -Xswiftc -DAGENT_ISLAND_USE_XCTEST
fi

echo "SKIP: XCTest runner requires the full Xcode macOS platform; tests are enforced in CI." >&2
if $require_xctest; then
  exit 1
fi
