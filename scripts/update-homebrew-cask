#!/usr/bin/env bash
# Copyright (c) 2026 Ling
# SPDX-License-Identifier: MIT

set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
CASK="$ROOT/Casks/agent-island.rb"
VERSION="${1:-}"
SHA256="${2:-}"

[[ "$VERSION" =~ ^[0-9]+\.[0-9]+\.[0-9]+$ ]] || { printf 'Usage: %s VERSION SHA256\n' "$0" >&2; exit 64; }
[[ "$SHA256" =~ ^[0-9a-fA-F]{64}$ ]] || { printf 'SHA256 must be 64 hexadecimal characters\n' >&2; exit 64; }

sed -i '' -E "s/version \"[0-9]+\.[0-9]+\.[0-9]+\"/version \"$VERSION\"/" "$CASK"
sed -i '' -E "s/sha256 \"[^\"]+\"/sha256 \"$SHA256\"/" "$CASK"
printf 'Updated %s for v%s\n' "$CASK" "$VERSION"
